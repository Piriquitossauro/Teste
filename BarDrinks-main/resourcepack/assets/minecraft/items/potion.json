{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "index": 0,
    "cases": [
      { "when": 1001, "model": { "type": "minecraft:model", "model": "minecraft:item/cerveja" } },
      { "when": 1002, "model": { "type": "minecraft:model", "model": "minecraft:item/coquetel_verde" } },
      { "when": 1003, "model": { "type": "minecraft:model", "model": "minecraft:item/coquetel_laranja" } },
      { "when": 1004, "model": { "type": "minecraft:model", "model": "minecraft:item/coquetel_vermelho" } }
    ],
    "fallback": {
      "type": "minecraft:special",
      "model": { "type": "minecraft:potion" },
      "base": "minecraft:item/potion"
    }
  }
}
